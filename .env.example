# Copy this file to .env and fill in your own values.
# NEVER commit the .env file to GitHub.

# ─── PostgreSQL / Google Cloud SQL ───────────────────────
DB_HOST=            # e.g. 34.xx.xx.xx  or  /cloudsql/project:region:instance
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=            # your Cloud SQL password

# ─── Google AI / Gemini ──────────────────────────────────
GEMINI_API_KEY=     # your Gemini Developer API key from aistudio.google.com

# ─── (Optional) Vertex AI fallback ───────────────────────
# GCP_PROJECT_ID=   # your GCP project ID (only needed if using Vertex AI)
# GOOGLE_APPLICATION_CREDENTIALS=GOOGLE_APPLICATION_CREDENTIALS.json
